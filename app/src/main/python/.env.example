# Copy this file to .env and fill real values.
GROQ_API_KEY=your_groq_api_key_here
RESFES_API_KEY=change_me_to_a_long_random_string
RESFES_PORT=5000
# Development-only escape hatch. Keep 0 in normal use.
# RESFES_ALLOW_OPEN_API=0
# Optional: set a fixed data directory
# RESFES_DATA_DIR=./knowledge
# Optional: force specific .env path
# RESFES_DOTENV_PATH=./app/src/main/python/.env
# Optional: remote extractor service for DOCX/PPTX/legacy Office/images on Android
# Example: RESFES_EXTRACTOR_SERVER_URL=http://192.168.1.10:8001
# RESFES_EXTRACTOR_SERVER_URL=
# RESFES_EXTRACTOR_TIMEOUT=8
