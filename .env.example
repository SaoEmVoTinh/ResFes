# ResFes Configuration
# ====================

# Knowledge Base Server URL (chạy trên điện thoại)
# Để trống nếu dùng local knowledge base
KB_SERVER_URL=

# Ví dụ: KB_SERVER_URL=http://192.168.1.100:5001

# Certificate options (khuyên dùng cho app đóng gói)
RESFES_CERT_DIR=.
RESFES_CERT_VALID_DAYS=365
RESFES_CERT_ROTATE_BEFORE_DAYS=14
RESFES_REGEN_CERT=false
